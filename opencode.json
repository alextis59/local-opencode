{
  "$schema": "https://opencode.ai/config.json",
  "model": "vibethinker-local/vibethinker-3b",
  "small_model": "vibethinker-local/vibethinker-3b",
  "provider": {
    "vibethinker-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "VibeThinker local gateway",
      "options": {
        "baseURL": "http://127.0.0.1:8088/v1",
        "apiKey": "local-vibethinker",
        "timeout": false,
        "headerTimeout": false,
        "chunkTimeout": 300000
      },
      "models": {
        "vibethinker-3b": {
          "name": "VibeThinker 3B Q4_K_M (local)",
          "family": "qwen2",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 8192,
            "output": 512
          }
        }
      }
    }
  }
}
