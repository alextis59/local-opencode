# Smith/OpenCode file-output benchmark profile for VibeThinker-3B on CPU.
# Copy to .env before running scripts/run_gateway.sh.
VIBETHINKER_MODEL_ID=vibethinker-3b
VIBETHINKER_MODEL_PATH=models/vibethinker-3b-q4_k_m.gguf
VIBETHINKER_HOST=127.0.0.1
VIBETHINKER_PORT=8088
VIBETHINKER_N_CTX=8192
VIBETHINKER_N_THREADS=2
VIBETHINKER_N_BATCH=512
VIBETHINKER_N_GPU_LAYERS=0
VIBETHINKER_DEFAULT_MAX_TOKENS=512
VIBETHINKER_MAX_TOKENS=512
VIBETHINKER_TEMPERATURE=0.2
VIBETHINKER_TOP_P=0.95
VIBETHINKER_TOP_K=40
VIBETHINKER_MIN_P=0.05
VIBETHINKER_REPEAT_PENALTY=1
VIBETHINKER_VERBOSE=false
VIBETHINKER_BUFFER_STREAM=true
VIBETHINKER_FALLBACK_TO_REASONING=true
VIBETHINKER_FORWARD_TOOLS=false
VIBETHINKER_RESPONSE_FORMAT=json_object
VIBETHINKER_LOG_COMPLETIONS=true
